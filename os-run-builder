#!/bin/bash
# os-run-builder — Automatyzacja izolacji Git Worktree dla Buildera
# Wersja: 6.0-swarm

if [ -z "$1" ]; then
    echo "Użycie: ./os-run-builder <nazwa_gałęzi_roboczej>"
    exit 1
fi

BRANCH_NAME=$1
TARGET_DIR="./tmp/worktrees/$BRANCH_NAME"

echo "Pranie osieroconych worktrees..."
git worktree prune

if [ -d "$TARGET_DIR" ]; then
    echo "Katalog worktree $TARGET_DIR już istnieje."
else
    echo "Tworzenie nowego, odizolowanego Git Worktree na gałęzi: $BRANCH_NAME..."
    if git rev-parse --verify "$BRANCH_NAME" >/dev/null 2>&1; then
        echo "Gałąź $BRANCH_NAME istnieje, podpinanie worktree..."
        git worktree add "$TARGET_DIR" "$BRANCH_NAME"
    else
        echo "Tworzenie nowej gałęzi $BRANCH_NAME i podpinanie worktree..."
        git worktree add -b "$BRANCH_NAME" "$TARGET_DIR" HEAD
    fi
fi

echo "========================================================================="
echo "✅ Git Worktree przygotowane pomyślnie!"
echo "📍 Katalog roboczy: $TARGET_DIR"
echo "🌿 Aktywna gałąź: $BRANCH_NAME"
echo "🛠️ Instrukcja: Wywołaj subagenta Builder, wskazując powyższą ścieżkę jako 'Workspace'."
echo "========================================================================="
