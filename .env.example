# ============================================================
# osint-lead-tracker — Zmienne Środowiskowe
# Skopiuj do .env i uzupełnij wartości
# ============================================================

# --- Google Gemini AI ---
GEMINI_API_KEY=your_gemini_api_key_here

# --- Odoo XML-RPC ---
ODOO_URL=https://your-odoo-instance.example.com
ODOO_DB=your_odoo_database_name
ODOO_USER=your_odoo_login@example.com
ODOO_PASSWORD=your_odoo_password

# ID zespołu sprzedaży w Odoo (crm.team)
# Zostaw 0 jeśli nie chcesz przypisywać
ODOO_TEAM_ID=0

# ID źródła leada w Odoo (utm.source)
# Zostaw 0 jeśli nie chcesz przypisywać
ODOO_SOURCE_ID=0

# --- Bezpieczeństwo API ---
# Losowy, silny token do zabezpieczenia endpointu /trigger-osint
API_TOKEN=change_me_to_a_strong_random_token

# --- Harmonogram (opcjonalne, domyślnie 06:00 Europe/Warsaw) ---
CRON_HOUR=6
CRON_MINUTE=0
CRON_TIMEZONE=Europe/Warsaw

# --- Baza danych ---
# Ścieżka wewnątrz kontenera (mapowana na wolumin hosta)
SQLITE_PATH=./data/leads.db
